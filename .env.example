# ── تحدي كأس العالم — إعدادات التشغيل ──
# انسخ هذا الملف إلى ‎.env وعدّل ما يلزم. متغيرات النظام لها الأولوية على هذا الملف.

# منفذ التطبيق
PORT=3000

# production | development ‏(development يُظهر تفاصيل الأخطاء في الاستجابة)
NODE_ENV=production

# فعّلها (1) عند التشغيل خلف HTTPS حتى تُرسل كوكي الجلسة بأمان
COOKIE_SECURE=0

# خلف Nginx اتركها 1 حتى تُقرأ عناوين IP الحقيقية في سجل التدقيق
TRUST_PROXY=1

# مسار قاعدة البيانات — اختياري، الافتراضي data/worldcup.db داخل المشروع
# DB_PATH=/opt/worldcup/data/worldcup.db

# سر توقيع JWT — اختياري؛ إن تُرك فارغاً يولَّد مرة واحدة ويُحفظ في قاعدة البيانات.
# حدّده هنا فقط إذا أردت تدويره أو تشغيل أكثر من نسخة.
# JWT_SECRET=
